{
  "name": "rss-to-email-vite",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist cache.json",
    "dev": "npm run clean && node server",
    "email": "node email",
    "harness": "node scripts/email-harness.mjs",
    "test": "vitest run",
    "verify": "npm run test && npm run build",
    "verify:full": "npm run verify && npm run harness",
    "build": "prettier --check . && tsc",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@react-email/container": "0.0.16",
    "@react-email/head": "0.0.13",
    "@react-email/hr": "0.0.12",
    "@react-email/html": "0.0.12",
    "@react-email/img": "0.0.12",
    "@react-email/link": "0.0.13",
    "@react-email/preview": "0.0.14",
    "@react-email/render": "1.4.0",
    "@react-email/section": "0.0.17",
    "@react-email/text": "0.1.6",
    "dayjs": "1.11.20",
    "node-html-parser": "6.1.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rss-parser": "3.13.0"
  },
  "devDependencies": {
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "express": "4.22.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  }
}
